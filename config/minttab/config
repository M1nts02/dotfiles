# MintTab — macOS window switcher configuration
# Location: ~/.config/minttab/config
# Format: key = value, lines starting with # are comments

# ---- Switching Mode ----

# switching: switch logic
#   app    — group by application (multiple windows of the same app merged into one icon)
#   window — group by window (each window displayed independently)
switching = window

# grouping: enable grouping feature (true/false)
#   when disabled, group-related hotkeys are not registered and show-all does not display group rows
grouping = true

# ---- Interface ----

# ui-style: interface style
#   icons — icons only
#   list  — icons + window title
ui-style = list

# ui-size: interface size
#   small  — small
#   medium — medium
#   large  — large
ui-size = medium

# blur: enable background blur effect (true/false)
blur = true

# mouse: enable mouse selection/hover (true/false)
mouse = true

# mouse-switch: switch immediately when releasing hotkey after hovering with mouse (true/false)
mouse-switch = true

# show-hidden: show Cmd+H hidden apps (true/false)
show-hidden = true

# show-windowless: show background apps with no windows (true/false)
show-windowless = false

# assign-switch: switch to the group after assigning via hotkey (true/false)
assign-switch = true

# auto-group: auto switch to the group of the current window when opening the switcher
auto-group = true

# show-all-cross-group: allow Tab/←→ to cross groups in show-all mode
show-all-cross-group = false

# switch-group-focus: auto focus the first window of the target group when switching groups
switch-group-focus = true

# ---- Keys ----

# switch-mod: switch key modifier (the key is always Tab)
#   alt — Alt+Tab
#   cmd — Cmd+Tab
#   ctrl — Ctrl+Tab
switch-mod = alt

# show-all: show all windows/apps (ignores group filter)
show-all = alt+grave

# ---- Group Switch (1–9, 9 groups total) ----
# Format: mod+key, available modifiers: alt, cmd, ctrl, shift
# Comment out a line to disable the hotkey for that group

group-switch-1 = ctrl+1
group-switch-2 = ctrl+2
group-switch-3 = ctrl+3
group-switch-4 = ctrl+4
group-switch-5 = ctrl+5
group-switch-6 = ctrl+6
group-switch-7 = ctrl+7
group-switch-8 = ctrl+8
group-switch-9 = ctrl+9

# ---- Group Assign (assign the current app to a specific group) ----
# Press the same combination again to unassign

# group-assign-1 = ctrl+shift+1
# group-assign-2 = ctrl+shift+2
# group-assign-3 = ctrl+shift+3
# group-assign-4 = ctrl+shift+4
# group-assign-5 = ctrl+shift+5
# group-assign-6 = ctrl+shift+6
# group-assign-7 = ctrl+shift+7
# group-assign-8 = ctrl+shift+8
# group-assign-9 = ctrl+shift+9

# ---- Group Navigation (unbound by default) ----
# Switch to next/previous non-empty group
# next-group = ctrl+right
# prev-group = ctrl+left
