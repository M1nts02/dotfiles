{
  "inlayHint.enable": false,
  "languageserver": {
    "clangd": {
      "command": "clangd",
      "rootPatterns": [
        "compile_flags.txt",
        "compile_commands.json"
      ],
      "filetypes": [
        "c",
        "cc",
        "cpp",
        "c++",
        "objc",
        "objcpp"
      ]
    },
    "zig": {
      "command": "zls",
      "rootPatterns": [
        "build.zig"
      ],
      "filetypes": [
        "zig"
      ]
    }
  }
}
